name: Update NSE Stocks to Google Sheet

on:
  workflow_dispatch:
  schedule:
    # Run at 20:15 IST (14:45 UTC) Monday–Friday — after market close and bhavcopy availability
    - cron: '45 14 * * 1-5'

jobs:
  update-sheet:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install gspread oauth2client pandas requests

      - name: Run update script
        env:
          GCP_CREDENTIALS: ${{ secrets.GCP_CREDENTIALS }}
          SPREADSHEET_ID: ${{ secrets.SPREADSHEET_ID }}
          # Optional overrides (set these as repository Variables if needed)
          # SHEET_NAME: 'Bhav Copy Data'
          # START_ROW: '8'
          # VOLUME_START_COL: 'A'
          # TURNOVER_START_COL: 'F'
        run: |
          python update_sheet.py --top 250 --mode both
